{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Repository handoff",
  "type": "object",
  "additionalProperties": false,
  "required": ["record_id", "created_at_utc", "source_agent", "status", "objective", "work_completed", "remaining_work", "decisions", "checks", "git_state", "index_state", "blockers", "artifacts", "next_action", "follow_up_queue"],
  "properties": {
    "record_id": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{6}Z-[a-f0-9]{7,40}$"},
    "created_at_utc": {"type": "string", "format": "date-time"},
    "source_agent": {"enum": ["codex", "claude-code"]},
    "status": {"enum": ["complete", "partial", "blocked"]},
    "objective": {"type": "string", "minLength": 1},
    "work_completed": {"type": "array", "items": {"type": "string"}},
    "remaining_work": {"type": "array", "items": {"type": "string"}},
    "decisions": {"type": "array", "items": {"type": "string"}},
    "checks": {"type": "array", "items": {"$ref": "#/$defs/check"}},
    "git_state": {
      "type": "object",
      "required": ["state", "root", "branch", "head", "upstream_relation", "worktree"],
      "additionalProperties": false,
      "properties": {
        "state": {"enum": ["current", "stale", "absent", "unknown"]},
        "root": {"type": ["string", "null"]},
        "branch": {"type": ["string", "null"]},
        "head": {"type": ["string", "null"]},
        "upstream_relation": {"type": "string"},
        "worktree": {"type": "string"}
      },
      "allOf": [
        {"if": {"properties": {"state": {"const": "absent"}}}, "then": {"properties": {"branch": {"type": "null"}, "head": {"type": "null"}}}},
        {"if": {"properties": {"state": {"const": "unknown"}}}, "then": {"properties": {"head": {"type": "null"}}}},
        {"if": {"properties": {"state": {"enum": ["current", "stale"]}}}, "then": {"properties": {"root": {"type": "string", "minLength": 1}, "branch": {"type": "string", "minLength": 1}, "head": {"type": "string", "pattern": "^([a-f0-9]{40}|[a-f0-9]{64})$"}}}}
      ]
    },
    "index_state": {"enum": ["current", "stale", "absent", "unknown", "not-configured"]},
    "blockers": {"type": "array", "items": {"type": "string"}},
    "artifacts": {"type": "array", "items": {"type": "string", "pattern": "^(?![A-Za-z]:|[\\\\/]|\\.\\.(?:[\\\\/]|$)|.*[\\\\/]\\.\\.(?:[\\\\/]|$)).+"}},
    "next_action": {"type": "object", "additionalProperties": false, "required": ["owner", "prerequisites", "action", "stop_condition"], "properties": {"owner": {"type": "string", "minLength": 1}, "prerequisites": {"type": "array", "items": {"type": "string"}}, "action": {"type": "string", "minLength": 1}, "stop_condition": {"type": "string", "minLength": 1}}},
    "follow_up_queue": {"type": "array", "items": {"type": "string"}}
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "complete"}}, "required": ["status"]}, "then": {"properties": {"git_state": {"properties": {"state": {"enum": ["current", "stale"]}}}}}}
  ],
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "state", "command", "exit_code", "evidence"],
      "properties": {"name": {"type": "string", "minLength": 1}, "state": {"enum": ["passed", "failed", "skipped", "not-run", "unknown", "not-configured", "unavailable"]}, "command": {"type": ["string", "null"]}, "exit_code": {"type": ["integer", "null"]}, "evidence": {"type": "string", "minLength": 1}},
      "allOf": [
        {"if": {"properties": {"state": {"const": "passed"}}}, "then": {"properties": {"command": {"type": "string", "minLength": 1}, "exit_code": {"const": 0}}}},
        {"if": {"properties": {"state": {"const": "failed"}}}, "then": {"properties": {"command": {"type": "string", "minLength": 1}, "exit_code": {"type": "integer", "not": {"const": 0}}}}},
        {"if": {"properties": {"state": {"enum": ["skipped", "not-run", "unknown", "not-configured", "unavailable"]}}}, "then": {"properties": {"exit_code": {"type": "null"}}}}
      ]
    }
  }
}
