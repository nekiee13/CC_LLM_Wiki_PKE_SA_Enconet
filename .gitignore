# Root ignore policy (Task C0.2, ADR-0002). See doc/GIT_CONVENTIONS.md.

# ADR-0002: sieving DATA corpora are never tracked; checksum manifests are.
*/sieving/DATA/

# Python caches and build artifacts
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/

# Database journals and local stores
*.db-journal
*.db-wal
*.db-shm
*.sqlite3-journal

# Obsidian local state (vault config stays tracked if ever added)
.obsidian/workspace*

# Agent-local settings (Claude and Codex local overrides stay per-machine)
.claude/settings.local.json
**/.claude/settings.local.json

# OS noise
Thumbs.db
.DS_Store
